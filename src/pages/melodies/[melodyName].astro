---
import SiteLayout from "../../layouts/SiteLayout.astro";
import { loadDataModel } from "../../lib/data";
import { getLineImage, getLineLogo } from "../../lib/branding";
import { stableEncode } from "../../lib/ids";

export async function getStaticPaths() {
  const data = await loadDataModel();
  return data.melodies.map((m) => ({ params: { melodyName: m.name } }));
}

const { melodyName } = Astro.params;
const data = await loadDataModel();
const melody = data.melodies.find((m) => m.name === melodyName);
if (!melody) throw new Error(`Melody not found: ${melodyName}`);

// Redirect to unused page if melody is unused
const isUnused = melody.usages.some((u) => u.station === "未使用" || u.line === "未使用");
if (isUnused) {
  return Astro.redirect(`/unused/${stableEncode(melody.name)}`);
}

// Group usages by company -> line -> station
const byCompany = new Map();
for (const u of melody.usages) {
  const c = byCompany.get(u.company) || new Map();
  const lKey = `${u.company}__${u.line}`;
  const l = c.get(lKey) || { company: u.company, line: u.line, lineId: u.lineId, stations: new Map() };
  const s = l.stations.get(u.stationId) || { station: u.station, stationId: u.stationId, entries: [] };
  s.entries.push(u);
  l.stations.set(u.stationId, s);
  c.set(lKey, l);
  byCompany.set(u.company, c);
}
const companyEntries = [...byCompany.entries()].sort((a, b) => a[0].localeCompare(b[0], "ja"));

// Get representative line for background
const representativeLine = melody.usages[0]?.line || "";
const lineImage = getLineImage(representativeLine);
---
<SiteLayout title={`${melody.name} — どこでも駅メロ`}>
  <nav class="breadcrumb meta" style="margin-bottom: 16px;">
    <a href="/">ホーム</a> &gt; 
    <a href="/melodies">メロディ</a> &gt; 
    <span>{melody.name}</span>
  </nav>

  <!-- Hero Section -->
  <div class="panel hero" style="position:relative; overflow:hidden; min-height:200px; display:flex; align-items:center; justify-content:center; margin-bottom: 24px; padding: 0;">
    {lineImage && (
      <img src={lineImage} alt={representativeLine} style="position:absolute; inset:0; width:100%; height:100%; object-fit:cover; z-index:0; filter: brightness(0.5) blur(2px);" />
    )}
    <div style="position:absolute; inset:0; background: rgba(0,0,0,0.3); z-index:1;"></div>
    <div style="position:relative; z-index:2; padding:40px 24px; text-align:center; color: white;">
      <h1 class="h1" style="margin:0; text-shadow:0 2px 10px rgba(0,0,0,0.8);">{melody.name}</h1>
      <div class="meta" style="color:rgba(255,255,255,0.9); margin-top:8px; font-weight: 500;">
        使用 {melody.usages.length}件
      </div>
      <div style="margin-top:24px;">
        <button
          class="btn"
          type="button"
          data-play
          data-url={melody.audioUrls[0]}
          data-title={melody.name}
          data-subtitle="メロディ"
          style="padding: 8px 24px; font-size: 20px; background: #fff; color: var(--accent); border: none; border-radius: 12px; cursor: pointer; box-shadow: 0 4px 10px rgba(0,0,0,0.2);"
        >
          ▶
        </button>
      </div>
    </div>
  </div>

  <div class="grid">
    <section class="panel col-12">
      <div class="panel-pad" style="border-bottom:1px solid var(--border); background: rgba(0,0,0,0.02);">
        <h2 style="font-size:1.1em; margin:0; font-weight:700;">使用されている駅</h2>
        <div class="meta">このメロディが流れる駅の一覧です。</div>
      </div>

      <div class="panel-pad">
        {companyEntries.map(([company, linesMap]) => {
          const lines = [...linesMap.values()].sort((a, b) => a.line.localeCompare(b.line, "ja"));
          return (
            <div style="margin-bottom:24px;">
              <div style="display:flex; align-items:center; gap:8px; margin-bottom: 12px;">
                <h3 style="font-size:1em; margin:0; border-left: 4px solid var(--border); padding-left: 10px; flex: 1; font-weight: 600;">
                  <a href={`/companies/${stableEncode(company)}`} style="color: inherit;">
                    {company}
                  </a>
                </h3>
                <a href={`/companies/${stableEncode(company)}`} class="btn" style="font-size: 12px; padding: 4px 10px;">会社へ</a>
              </div>
              <div class="grid">
                {lines.map((l) => {
                  const stations = [...l.stations.values()].sort((a, b) => a.station.localeCompare(b.station, "ja"));
                  const stationIndices = new Map(stations.map((s) => [s.stationId, s.station]));
                  return (
                    <div class="panel col-6" style="display: flex; flex-direction: column;">
                      <div class="panel-pad" style="border-bottom:1px solid var(--border); display:flex; justify-content:space-between; gap:12px; align-items:center; background: rgba(0,0,0,0.01);">
                        <div style="display:flex; align-items:center; gap:8px;">
                          <img src={getLineLogo(l.line)} alt="" style="height:20px; width:auto;" onerror="this.style.display='none'" />
                          <a href={`/lines/${stableEncode(l.line)}`} style="font-weight:600; color: inherit;">{l.line}</a>
                        </div>
                        <div class="meta">{stations.length}駅</div>
                      </div>
                      <ul class="list" style="flex: 1;">
                        {stations.map((s) => (
                          <li>
                            <div style="flex: 1;">
                              <a href={`/stations/${stableEncode(s.station)}`} style="font-weight:600;">{s.station}駅</a>
                              <div class="meta">{s.entries.map(e => e.track ? `${e.track}番線` : "").filter(Boolean).join(", ")}</div>
                            </div>
                            <a class="btn" href={`/stations/${stableEncode(s.station)}`} style="font-size: 12px; padding: 4px 10px;">駅へ</a>
                          </li>
                        ))}
                      </ul>
                    </div>
                  );
                })}
              </div>
            </div>
          );
        })}
      </div>
    </section>
  </div>
</SiteLayout>
