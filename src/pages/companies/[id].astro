---
import SiteLayout from "../../layouts/SiteLayout.astro";
import { loadDataModel } from "../../lib/data";
import { stableEncode } from "../../lib/ids";
import { companyLogo, companyBrandColor, getLineLogo } from "../../lib/branding";

export async function getStaticPaths() {
  const data = await loadDataModel();
  const companies = [...new Set(data.usages.map((u) => u.company))];
  return companies.map((company) => ({ params: { id: company } }));
}

const { id } = Astro.params;
const companyName = id ?? "";
const data = await loadDataModel();
const usages = data.usages.filter((u) => u.company === companyName);
if (!usages.length) throw new Error(`Company not found: ${companyName}`);

const lines = data.lines
  .filter((l) => l.company === companyName)
  .filter((l) => l.line !== "特急用ホーム" && l.line !== "未使用")
  .sort((a, b) => b.stationIds.length - a.stationIds.length);
const stationIds = new Set(usages.map((u) => u.stationId));
const melodyMap = new Map<string, { name: string; audioUrl: string; count: number }>();
for (const u of usages) {
  const cur = melodyMap.get(u.melodyId) ?? { name: u.melody, audioUrl: u.audioUrl, count: 0 };
  cur.count += 1;
  melodyMap.set(u.melodyId, cur);
}
const topMelodies = [...melodyMap.entries()]
  .map(([melodyId, v]) => ({ melodyId, ...v }))
  .sort((a, b) => b.count - a.count)
  .slice(0, 20);

const brandColor = companyBrandColor(companyName);
const companyImageMap: Record<string, string> = {
  "JR東日本": "/images/JR_East.jpg",
  "都営地下鉄": "/images/toei.jpg",
  "東京メトロ": "/images/tokyo-metro.jpg",
};
const companyImage = companyImageMap[companyName];
---
<SiteLayout title={`${companyName} — どこでも駅メロ`}>
  <nav class="breadcrumb meta" style="margin-bottom: 16px;">
    <a href="/">ホーム</a> &gt; 
    <a href="/companies">会社別</a> &gt; 
    <span>{companyName}</span>
  </nav>

  <!-- Hero Section -->
  <div class="panel hero" style="position:relative; overflow:hidden; min-height:200px; display:flex; align-items:center; justify-content:center; margin-bottom: 24px; padding: 0;">
    {companyImage && (
      <img src={companyImage} alt={companyName} style="position:absolute; inset:0; width:100%; height:100%; object-fit:cover; z-index:0; filter: brightness(0.5) blur(2px);" />
    )}
    <div style="position:absolute; inset:0; background: rgba(0,0,0,0.3); z-index:1;"></div>
    <div style="position:relative; z-index:2; padding:40px 24px; text-align:center; color: white;">
      <div style="display:flex; align-items:center; justify-content:center; gap:16px; margin-bottom: 12px;">
        {companyLogo(companyName) && (
          <img src={companyLogo(companyName)} alt={companyName} style="height:48px; width:auto; filter: drop-shadow(0 2px 4px rgba(0,0,0,0.3));" />
        )}
        <h1 class="h1" style="margin:0; text-shadow:0 2px 10px rgba(0,0,0,0.8);">{companyName}</h1>
      </div>
      <div class="meta" style="color:rgba(255,255,255,0.9); font-weight: 500; font-size: 1.1em;">
        路線 {lines.length}件 ・ 駅 {stationIds.size}件 ・ 使用 {usages.length}件
      </div>
    </div>
  </div>

  <div class="grid">
    <section class="panel col-6">
      <div class="panel-pad" style="border-bottom:1px solid var(--border); display:flex; justify-content:space-between; align-items:center; background: rgba(0,0,0,0.02);">
        <h2 style="font-size:1.1em; margin:0; font-weight:700;">路線一覧</h2>
        <a class="btn" href="/lines" style="font-size: 12px; padding: 4px 12px;">全路線を見る</a>
      </div>
      <ul class="list">
        {lines.map((l) => (
          <li>
            <div style="flex: 1;">
              <div style="display:flex; align-items:center; gap:8px;">
                <img src={getLineLogo(l.line)} alt="" style="height:20px; width:auto;" onerror="this.style.display='none'" />
                <a href={`/lines/${stableEncode(l.line)}`} style="font-weight:600; color: inherit;">{l.line}</a>
              </div>
              <div class="meta" style="margin-top:2px;">駅 {l.stationIds.length}駅 ・ 使用 {l.usages.length}件</div>
            </div>
            <a class="btn" href={`/lines/${stableEncode(l.line)}`} style="font-size: 12px; padding: 4px 10px;">開く</a>
          </li>
        ))}
      </ul>
    </section>

    <section class="panel col-6">
      <div class="panel-pad" style="border-bottom:1px solid var(--border); display:flex; justify-content:space-between; align-items:center; background: rgba(0,0,0,0.02);">
        <h2 style="font-size:1.1em; margin:0; font-weight:700;">人気メロディ</h2>
        <a class="btn" href="/melodies" style="font-size: 12px; padding: 4px 12px;">全メロディを見る</a>
      </div>
      <ul class="list">
        {topMelodies.map((m) => (
          <li>
            <div style="flex: 1;">
              <a href={`/melodies/${stableEncode(m.name)}`} style="font-weight:600; color: inherit;">{m.name}</a>
              <div class="meta" style="margin-top:2px;">使用 {m.count}件</div>
            </div>
            <div style="display:flex; gap:8px; align-items:center;">
              <button class="btn btn-primary" data-play data-url={m.audioUrl} data-title={m.name} data-subtitle={companyName} style="padding: 4px 8px; font-size: 14px; font-weight: 600; min-width: auto;" title="再生">▶</button>
              <a class="btn" href={`/melodies/${stableEncode(m.name)}`} style="font-size: 12px; padding: 4px 10px;">開く</a>
            </div>
          </li>
        ))}
      </ul>
    </section>
  </div>
</SiteLayout>

